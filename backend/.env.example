# Backend
PORT=8080
LOG_LEVEL=info

# CORS
# On prod, change to: CORS_ORIGINS=https://your-project.web.app
CORS_ORIGINS=*

# Model
MODEL_PATH=../model/credit_model.joblib
FEATURES_PATH=../model/features.joblib

# AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=

# Global daily cap on /email calls, shared across all clients — cost guardrail
# independent of the per-IP rate limit.
EMAIL_DAILY_LIMIT=100

# LANGSMITH (optional — enables LangGraph trace observability at smith.langchain.com)
# Uncomment and fill in to activate tracing.
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxx
# LANGCHAIN_PROJECT=loan-default-predictor
